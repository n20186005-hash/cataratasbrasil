---
import type { Lang } from '../i18n/utils';
import { translations } from '../i18n/translations';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = (s: Record<string, string> | string) => typeof s === 'string' ? s : s[lang] || s.pt || '';

const ft = translations.footer as any;
---

<footer class="bg-[color:var(--color-ink)] text-[color:var(--color-cream)]">
  <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-6">
      <h2 class="font-display text-4xl md:text-5xl leading-tight" set:html={t(ft.cta)} />
      <p class="mt-6 text-white/70 max-w-md">{t(ft.address)}</p>
    </div>
    <div class="md:col-span-3">
      <div class="text-xs uppercase tracking-widest text-[color:var(--color-sun)] mb-4">Location</div>
      <div class="space-y-1 text-white/80">
        <div>Plus Code · 8H86+35</div>
        <div>Foz do Iguaçu — PR</div>
        <div>Brasil</div>
        <div class="mt-4">
          <a href="https://maps.app.goo.gl/kbFrrWhUT49eiEjk6" target="_blank" rel="noopener" class="link-underline text-[color:var(--color-sun)]">Google Maps →</a>
        </div>
      </div>
    </div>
    <div class="md:col-span-3">
      <div class="text-xs uppercase tracking-widest text-[color:var(--color-sun)] mb-4">Rating</div>
      <div class="num-display text-5xl">4.9</div>
      <div class="text-white/60 text-sm">8,954 reviews</div>
    </div>
  </div>
  <div class="border-t border-white/10 py-6 text-center text-xs text-white/40">
    {ft.copyright}
  </div>
</footer>
