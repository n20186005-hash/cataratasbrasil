---
import type { Lang } from '../i18n/utils';
import { translations } from '../i18n/translations';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = (s: Record<string, string> | string) => typeof s === 'string' ? s : s[lang] || s.pt || '';

const pr = translations.practical as any;
const cards = pr.cards as any[];
---

<section id="practical" class="max-w-7xl mx-auto px-6 py-24 md:py-32">
  <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)]">03 — {t(pr.sectionNum)}</div>
  <h2 class="font-display text-4xl md:text-6xl mt-4 mb-14 max-w-3xl" set:html={t(pr.heading)} />

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
    {cards.map((card: any, i: number) => (
      <div class={`rounded-3xl bg-white border border-black/5 p-6 ${i === 3 ? 'bg-[color:var(--color-sun)]/20 border-[color:var(--color-sun)]/40' : ''}`}>
        <div class="text-3xl">{card.icon}</div>
        <div class="text-xs uppercase tracking-widest text-[color:var(--color-emerald)] mt-4">{t(card.label)}</div>
        {card.value && <div class="font-display text-2xl mt-1">{card.value}</div>}
        {card.tips ? (
          <ul class="mt-2 space-y-1.5 text-sm text-[color:var(--color-ink)]">
            {card.tips.map((tip: any) => <li>💧 {t(tip)}</li>)}
          </ul>
        ) : (
          <p class="text-sm text-[color:var(--color-moss)]/80 mt-2">{t(card.desc)}</p>
        )}
      </div>
    ))}
  </div>
</section>
