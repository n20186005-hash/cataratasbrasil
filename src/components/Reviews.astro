---
import type { Lang } from '../i18n/utils';
import { reviews } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
---
<section id="reviews" class="max-w-7xl mx-auto px-6 py-24 md:py-32">
  <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
    <div><div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)]">07 — {_(reviews.sectionNum)}</div>
    <h2 class="font-display text-4xl md:text-6xl mt-4" set:html={_(reviews.heading)} /></div>
    <div class="flex gap-1 text-3xl text-[color:var(--color-sun)]">★★★★★</div>
  </div>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {reviews.items.map((review) => (
      <article class="rounded-3xl bg-white border border-black/5 p-7">
        <div class="flex items-center justify-between"><div class="text-[color:var(--color-sun)]" set:html={review.stars} /><div class="text-xs text-[color:var(--color-moss)]/60">{review.date}</div></div>
        <h4 class="font-display text-xl mt-3" set:html={_(review.title)} />
        <p class="mt-3 text-[color:var(--color-moss)] leading-relaxed text-sm">{_(review.desc)}</p>
        <div class="mt-5 text-sm text-[color:var(--color-emerald)]">{review.author}</div>
      </article>
    ))}
  </div>
</section>
