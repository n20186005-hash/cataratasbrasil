---
import type { Lang } from '../i18n/utils';
import { gallery } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
const imgs = Array.from({ length: 20 }, (_, i) => `/gallery/trilha-das-cataratas-brasil (${i + 1}).jpg`);
const bento = [
  'col-span-8 row-span-2 aspect-[16/10]','col-span-4 aspect-square','col-span-4 aspect-square',
  'md:col-span-4 col-span-6 aspect-[4/3]','md:col-span-4 col-span-6 aspect-[4/3]','md:col-span-4 col-span-12 aspect-[4/3]',
  'md:col-span-3 col-span-6 aspect-[4/3]','md:col-span-3 col-span-6 aspect-[4/3]','md:col-span-3 col-span-6 aspect-[4/3]','md:col-span-3 col-span-6 aspect-[4/3]',
  'col-span-4 aspect-square','col-span-8 aspect-[16/10]',
  'md:col-span-3 col-span-6 aspect-[4/3]','md:col-span-3 col-span-6 aspect-[4/3]','md:col-span-3 col-span-6 aspect-[4/3]','md:col-span-3 col-span-6 aspect-[4/3]',
  'col-span-4 aspect-square','col-span-8 aspect-[16/9]','col-span-6 aspect-[4/3]','col-span-6 aspect-[4/3]',
];
---
<section id="gallery" class="bg-[color:var(--color-ink)] text-white py-24 md:py-32 grain">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
      <div><div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-sun)]">06 — {_(gallery.sectionNum)}</div>
      <h2 class="font-display text-4xl md:text-6xl mt-4">{_(gallery.heading)}</h2></div>
    </div>
    <div class="grid grid-cols-12 gap-3 md:gap-4">
      {imgs.map((src, i) => (
        <figure class={`${bento[i] || 'col-span-6 aspect-[4/3]'} rounded-2xl overflow-hidden`}>
          <img loading="lazy" alt={`Trilha das Cataratas — gallery photo ${i + 1}`} class="w-full h-full object-cover hover:scale-105 transition duration-700" src={src} />
        </figure>
      ))}
    </div>
  </div>
</section>
