---
import type { Lang } from '../i18n/utils';
import { translations } from '../i18n/translations';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = (s: Record<string, string> | string) => typeof s === 'string' ? s : s[lang] || s.pt || '';

const gl = translations.gallery as any;
const galleryImages = Array.from({ length: 20 }, (_, i) => `/gallery/trilha-das-cataratas-brasil (${i + 1}).jpg`);

/* Bento layout mapping: [col-span, row-span, aspect] */
const bentoLayout = [
  { span: 'col-span-8 row-span-2', ar: 'aspect-[16/10]' },
  { span: 'col-span-4', ar: 'aspect-square' },
  { span: 'col-span-4', ar: 'aspect-square' },
  { span: 'md:col-span-4 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-4 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-4 col-span-12', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'col-span-4', ar: 'aspect-square' },
  { span: 'col-span-3 col-span-8', ar: 'aspect-[16/10]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'md:col-span-3 col-span-6', ar: 'aspect-[4/3]' },
  { span: 'col-span-4', ar: 'aspect-square' },
  { span: 'col-span-8', ar: 'aspect-[16/9]' },
  { span: 'col-span-6', ar: 'aspect-[4/3]' },
  { span: 'col-span-6', ar: 'aspect-[4/3]' },
];
---

<section id="gallery" class="bg-[color:var(--color-ink)] text-white py-24 md:py-32 grain">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-sun)]">06 — {t(gl.sectionNum)}</div>
        <h2 class="font-display text-4xl md:text-6xl mt-4">{t(gl.heading)}</h2>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-3 md:gap-4">
      {galleryImages.map((src, i) => {
        const lo = bentoLayout[i] || { span: 'col-span-6', ar: 'aspect-[4/3]' };
        return (
          <figure class={`${lo.span} ${lo.ar} rounded-2xl overflow-hidden`}>
            <img
              loading="lazy"
              alt={`Trilha das Cataratas — gallery photo ${i + 1}`}
              class="w-full h-full object-cover hover:scale-105 transition duration-700"
              src={src}
            />
          </figure>
        );
      })}
    </div>
  </div>
</section>
